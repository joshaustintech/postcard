<!--
  This post is available in Markdown format.
  Add .md to the URL: <%= public_post_url(@post, format: :md, host: @account.host) %>
-->

<% content_for :head do %>
  <% if @account.code %>
    <%= raw @account.code %>
  <% end %>
  <% if @post.visibility_hidden? %>
    <% nofollow %>
  <% end %>
<% end %>

<% title @post.subject %>

<%= render 'posts/post', post: @post, disabled: false %>
